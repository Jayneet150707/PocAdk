# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
VERTEX_AI_LOCATION=us-central1

# Vertex AI Model Configuration
VERTEX_AI_MODEL_NAME=gemini-1.5-pro
VERTEX_AI_ENDPOINT_ID=your-endpoint-id

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# Agent Configuration
AGENT_NAME=credit-assessment-agent
AGENT_VERSION=0.1.0
MAX_CONCURRENT_ASSESSMENTS=10

# Credit Assessment Configuration
CONFIDENCE_THRESHOLD=0.7
RISK_SCORE_WEIGHTS_CREDIT=0.4
RISK_SCORE_WEIGHTS_TRANSACTIONS=0.3
RISK_SCORE_WEIGHTS_APPLICATION=0.3

# PDF Processing Configuration
MAX_PDF_SIZE_MB=10
PDF_PROCESSING_TIMEOUT=30

# Database Configuration (Optional for future use)
DATABASE_URL=sqlite:///./credit_assessments.db

# Security Configuration
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Monitoring and Logging
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_FORMAT=json
