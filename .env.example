# Google Cloud Configuration
# Replace 'your-project-id' with your actual Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Path to your service account key file
# Download this from Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Vertex AI Configuration
# Available locations: us-central1, us-east1, us-west1, europe-west1, asia-southeast1
VERTEX_AI_LOCATION=us-central1

# Vertex AI Model to use
# Options: gemini-1.5-flash-001, gemini-1.5-pro-001, gemini-pro
VERTEX_AI_MODEL=gemini-1.5-flash-001

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: Custom model parameters
VERTEX_AI_TEMPERATURE=0.7
VERTEX_AI_MAX_TOKENS=1000
VERTEX_AI_TOP_P=0.8
VERTEX_AI_TOP_K=40

# Optional: Assessment thresholds
CONFIDENCE_THRESHOLD=0.6
RISK_SCORE_THRESHOLD=650
MAX_DEBT_TO_INCOME_RATIO=0.36

# Optional: Database configuration (for future use)
# DATABASE_URL=sqlite:///./credit_assessments.db

# Optional: Redis configuration (for caching)
# REDIS_URL=redis://localhost:6379/0

# Optional: Monitoring and observability
# ENABLE_METRICS=true
# METRICS_PORT=9090

